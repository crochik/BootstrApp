    <JsonDataSource Name="Categories" ConnectionName="jsonCategories" RootElement="Products" ComponentName="jsonDataSource1" />
  </DataSources>
  <Items>
    <TabContainer ComponentName="tabContainerDashboardItem1" Name="Tab Container 1">
      <Pages>
        <Page ComponentName="dashboardTabPage1" Name="Products" />
