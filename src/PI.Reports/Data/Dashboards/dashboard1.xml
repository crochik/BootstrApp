      </Pages>
    </TabContainer>
    <Grid ComponentName="gridDashboardItem1" Name="Grid 1" ParentContainer="dashboardTabPage1" DataSource="jsonDataSource1">
      <DataItems>
        <Dimension DataMember="ProductName" DefaultId="DataItem0" />
        <Dimension DataMember="ReorderLevel" DefaultId="DataItem1" />
        <Dimension DataMember="UnitPrice" DefaultId="DataItem2" />
      </DataItems>
      <GridColumns>
        <GridDimensionColumn>
          <Dimension DefaultId="DataItem0" />
        </GridDimensionColumn>
        <GridDimensionColumn DisplayMode="Image">
          <Dimension DefaultId="DataItem1" />
        </GridDimensionColumn>
        <GridDimensionColumn>
          <Dimension DefaultId="DataItem2" />
        </GridDimensionColumn>
      </GridColumns>
      <GridOptions />
      <ColumnFilterOptions />
    </Grid>
    <ComboBox ComponentName="comboBoxDashboardItem1" Name="Combo Box 1" DataSource="jsonDataSource1">
      <DataItems>
        <Dimension DataMember="Discontinued" DefaultId="DataItem0" />
      </DataItems>
      <FilterDimensions>
        <Dimension DefaultId="DataItem0" />
      </FilterDimensions>
    </ComboBox>
    <TreeView ComponentName="treeViewDashboardItem1" Name="Tree View 1" ParentContainer="dashboardTabPage1" DataSource="jsonDataSource1">
      <DataItems>
        <Dimension DataMember="CategoryId" DefaultId="DataItem0" />
