<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Webhook.Integrations.Core</RootNamespace>
    <AssemblyName>Webhook.Integrations.Core</AssemblyName>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Uses ASP.NET Core types (HttpContext, IApplicationBuilder) for the API-key
       middleware and DI helpers, but ships no endpoints of its own. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Durable outbound delivery pipeline reused by every integration. -->
    <ProjectReference Include="..\Webhook.Publisher\Webhook.Publisher.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Webhook.Integrations.Core.Tests" />
  </ItemGroup>

</Project>
