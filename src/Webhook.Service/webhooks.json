{
  "Webhooks": {
    "Definitions": [
      {
        "Uuid": "github-0000-0000-0000-000000000001",
        "Name": "github",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "X-Hub-Signature-256",
            "Algorithm": "sha256",
            "Encoding": "hex",
            "Prefix": "sha256=",
            "Secret": "change-me-github-webhook-secret"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 204, "ContentType": "text/plain", "Body": "" }
      },
      {
        "Uuid": "facebook-0000-0000-0000-000000000002",
        "Name": "facebook",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "X-Hub-Signature-256",
            "Algorithm": "sha256",
            "Encoding": "hex",
            "Prefix": "sha256=",
            "Secret": "change-me-facebook-app-secret"
          }
        ],
        "Registration": {
          "Mode": "challengeQuery",
          "ChallengeParam": "hub.challenge",
          "VerifyParam": "hub.verify_token",
          "VerifyValue": "change-me-facebook-verify-token"
        },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "EVENT_RECEIVED" }
      },
      {
        "Uuid": "google00-0000-0000-0000-000000000003",
        "Name": "google",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Google Calendar/Drive push: verify the channel token you set at watch() time.",
        "Auth": [
          {
            "Type": "apikey",
            "Header": "X-Goog-Channel-Token",
            "Token": "change-me-google-channel-token"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "" }
      },
      {
        "Uuid": "sendgrid-0000-0000-0000-000000000004",
        "Name": "sendgrid",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "SendGrid Event Webhook: ECDSA over timestamp+body. PublicKey is the base64 verification key from the SendGrid UI.",
        "Auth": [
          {
            "Type": "ecdsa",
            "Header": "X-Twilio-Email-Event-Webhook-Signature",
            "TimestampHeader": "X-Twilio-Email-Event-Webhook-Timestamp",
            "PublicKey": "change-me-base64-ecdsa-public-key"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "twilio00-0000-0000-0000-000000000005",
        "Name": "twilio",
        "Enabled": true,
        "Handler": "logging",
        "Format": "form",
        "_comment": "Twilio signs URL + sorted form params with HMAC-SHA1. Set Url to the exact public webhook URL when behind a proxy/tunnel.",
        "Auth": [
          {
            "Type": "twilio",
            "Header": "X-Twilio-Signature",
            "Token": "change-me-twilio-auth-token",
            "Url": "https://example.com/webhooks/twilio00-0000-0000-0000-000000000005"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": {
          "Status": 200,
          "ContentType": "application/xml",
          "Body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><Response></Response>"
        }
      },
      {
        "Uuid": "compycam-0000-0000-0000-000000000006",
        "Name": "companycam",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "CompanyCam signs the raw body with HMAC-SHA1 (base64) keyed by the webhook token.",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "X-CompanyCam-Signature",
            "Algorithm": "sha1",
            "Encoding": "base64",
            "Secret": "change-me-companycam-webhook-token"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "office365-0000-0000-0000-00000000007",
        "Name": "office365",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Graph validates the URL with POST ?validationToken=... (answered before auth). Notifications carry clientState in each value[] item.",
        "Auth": [
          { "Type": "bodyField", "Path": "value[].clientState", "Value": "change-me-graph-client-state" }
        ],
        "Registration": {
          "Mode": "challengeQuery",
          "ChallengeParam": "validationToken"
        },
        "Response": { "Status": 202, "ContentType": "text/plain", "Body": "" }
      },
      {
        "Uuid": "stripe00-0000-0000-0000-000000000008",
        "Name": "stripe",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Stripe-Signature: t=...,v1=...; HMAC-SHA256 (hex) over {t}.{body}; secret is whsec_...",
        "Auth": [
          { "Type": "stripe", "Header": "Stripe-Signature", "Secret": "whsec_change-me" }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "slack000-0000-0000-0000-000000000009",
        "Name": "slack",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Slack signs v0:{timestamp}:{body} with HMAC-SHA256 (hex), header X-Slack-Signature prefixed v0=.",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "X-Slack-Signature",
            "Algorithm": "sha256",
            "Encoding": "hex",
            "Prefix": "v0=",
            "Template": "v0:{timestamp}:{body}",
            "TimestampHeader": "X-Slack-Request-Timestamp",
            "Secret": "change-me-slack-signing-secret"
          }
        ],
        "Registration": {
          "Mode": "challengeBody",
          "TriggerField": "type",
          "TriggerValue": "url_verification",
          "ChallengeField": "challenge"
        },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "" }
      },
      {
        "Uuid": "k8s00000-0000-0000-0000-000000000010",
        "Name": "kubernetes-admission",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "k8s admission webhook: mutual TLS (configure Kestrel to negotiate client certs). Responds with an AdmissionReview echoing request.uid.",
        "Auth": [
          { "Type": "clientCert", "Thumbprints": [ "CHANGE-ME-APISERVER-CLIENT-CERT-THUMBPRINT" ] }
        ],
        "Registration": { "Mode": "none" },
        "Response": {
          "Status": 200,
          "ContentType": "application/json",
          "Body": "{\"apiVersion\":\"admission.k8s.io/v1\",\"kind\":\"AdmissionReview\",\"response\":{\"uid\":\"{{json:request.uid}}\",\"allowed\":true}}"
        }
      },
      {
        "Uuid": "marchex0-0000-0000-0000-000000000011",
        "Name": "marchex",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Marchex ms-signature: sha256=<hash>, HMAC-SHA256 over body. Basic auth is also offered by Marchex as an alternative.",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "ms-signature",
            "Algorithm": "sha256",
            "Encoding": "hex",
            "Prefix": "sha256=",
            "Secret": "change-me-marchex-private-key"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "openphn0-0000-0000-0000-000000000012",
        "Name": "openphone",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "openphone-signature: hmac;1;{timestamp};{base64sig}; HMAC-SHA256 over {timestamp}.{body}; signing key is base64-decoded.",
        "Auth": [
          { "Type": "openphone", "Header": "openphone-signature", "Secret": "Y2hhbmdlLW1lLW9wZW5waG9uZS1zaWduaW5nLWtleQ==" }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "quickbk0-0000-0000-0000-000000000013",
        "Name": "quickbooks",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Intuit intuit-signature: base64 HMAC-SHA256 over the raw body, keyed by the verifier token.",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "intuit-signature",
            "Algorithm": "sha256",
            "Encoding": "base64",
            "Secret": "change-me-quickbooks-verifier-token"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "salesfc0-0000-0000-0000-000000000014",
        "Name": "salesforce",
        "Enabled": true,
        "Handler": "logging",
        "Format": "xml",
        "_comment": "Salesforce Outbound Messages are SOAP/XML with no signature. Authenticate via mutual TLS (clientCert) and/or the Salesforce IP allowlist.",
        "Auth": [
          { "Type": "ipAllowlist", "Ranges": [ "13.108.0.0/14", "96.43.144.0/20" ], "TrustForwardedFor": false }
        ],
        "Registration": { "Mode": "none" },
        "Response": {
          "Status": 200,
          "ContentType": "text/xml",
          "Body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\"><soap:Body><notificationsResponse xmlns=\"http://soap.sforce.com/2005/09/outbound\"><Ack>true</Ack></notificationsResponse></soap:Body></soap:Envelope>"
        }
      },
      {
        "Uuid": "typefrm0-0000-0000-0000-000000000015",
        "Name": "typeform",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Typeform-Signature: sha256=<base64 HMAC-SHA256 of raw body>.",
        "Auth": [
          {
            "Type": "hmac",
            "Header": "Typeform-Signature",
            "Algorithm": "sha256",
            "Encoding": "base64",
            "Prefix": "sha256=",
            "Secret": "change-me-typeform-secret"
          }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "text/plain", "Body": "OK" }
      },
      {
        "Uuid": "zapier00-0000-0000-0000-000000000016",
        "Name": "zapier",
        "Enabled": true,
        "Handler": "logging",
        "Format": "json",
        "_comment": "Zapier has no native signature; secure with a shared header secret (or rely on the unguessable URL).",
        "Auth": [
          { "Type": "apikey", "Header": "X-Webhook-Secret", "Token": "change-me-zapier-shared-secret" }
        ],
        "Registration": { "Mode": "none" },
        "Response": { "Status": 200, "ContentType": "application/json", "Body": "{\"received\":true}" }
      }
    ]
  }
}
