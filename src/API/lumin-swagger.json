                "start": {
                    "format": "date-time",
                    "type": "string"
                },
                "end": {
                    "format": "date-time",
                    "type": "string"
                },
                "appointmentTypeId": {
                    "format": "uuid",
                    "type": "string"
                },
                "appointmentDurationInMinutes": {
                    "format": "int32",
                    "type": "integer"
                },
                "timeZoneId": {
                    "type": "string",
                    "readOnly": true
