        "LuminUpcomingAppointment": {
            "type": "object",
            "properties": {
                "id": {
                    "format": "uuid",
                    "type": "string"
                },
                "start": {
                    "format": "date-time",
                    "type": "string"
                },
                "end": {
                    "format": "date-time",
                    "type": "string"
                }
