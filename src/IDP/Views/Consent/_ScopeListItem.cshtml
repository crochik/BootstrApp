@model IDP.Models.ScopeViewModel

<li class="scope-item">
    <label>
        <input type="checkbox"
               name="ScopesConsented"
               value="@Model.Value"
               checked="@Model.Checked"
               disabled="@Model.Required" />
        @if (Model.Required)
        {
            <input type="hidden" name="ScopesConsented" value="@Model.Value" />
        }
        <span>
            <span class="scope-name">@Model.DisplayName</span>
            @if (Model.Description != null)
            {
                <span class="scope-description">@Model.Description</span>
            }
        </span>
    </label>
</li>
