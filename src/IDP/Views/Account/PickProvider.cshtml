@model IDP.Models.PickProviderViewModel
@using System.Linq
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Select Authentication Provider</title>

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            background-color: #f7fafc;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .code {
            margin-top: 40px;
            padding: 10px;
        }
        .code-button {
            align-items: center;
            justify-content: center;
            padding: 10px;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 5px;
            border: 1px solid #7cc;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            transition: all 150ms ease-in-out;
            text-decoration: none;
        }
        .code-text {
            color: #7cc;
        }

        .card {
            background-color: #fff;
            max-width: 448px;
            width: 100%;
            padding: 2.5rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            border-radius: 1rem;
            border-top: 8px solid #4f46e5;
            transition: all 300ms ease;
            box-sizing: border-box;
        }

        .header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #111827;
            margin: 0 0 0.5rem 0;
        }
        .subtitle {
            font-size: 1rem;
            color: #6b7280;
            margin: 0;
        }

        .provider-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .provider-button {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 90%;
            padding: 0.75rem 1.25rem;
            border: 1px solid #d1d5db;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 0.5rem;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            transition: all 150ms ease-in-out;
            text-decoration: none;
            background-color: #fff;
        }
        .provider-button:hover {
            border-color: #9ca3af;
            background-color: #f3f4f6;
        }

        .provider-logo {
            width: 1.5rem;
            height: 1.5rem;
            margin-right: 0.75rem;
            flex-shrink: 0;
        }

        .header-icon {
            width: 2rem;
            height: 2rem;
            color: #4f46e5;
            margin: 0 auto 0.5rem;
            display: block;
        }
    </style>
</head>
<body>

<div class="card">

    <div class="header">
        <svg class="header-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
        </svg>
        <h1 class="title">Sign In to Your Account</h1>
        <p class="subtitle">Select your primary authentication provider to continue.</p>
    </div>

    <div class="provider-list">

        @foreach (var entry in Model.Providers.Where(p => p.Key != "MagicCode"))
        {
            string borderColor = null;
            string textColor = null;
            switch (entry.Key)
            {
                case "Google":     borderColor = textColor = "#4285F4"; break;
                case "Microsoft":  borderColor = textColor = "#0078D4"; break;
                case "Salesforce": borderColor = textColor = "#00A1E0"; break;
                case "GitHub":     borderColor = textColor = "#000000"; break;
            }
            var style = borderColor != null ? $"border-color: {borderColor}; color: {textColor};" : null;

            <a asp-controller="Account" asp-action="Login"
               asp-route-provider="@entry.Key" asp-route-returnUrl="@Model.ReturnUrl"
               class="provider-button"
               style="@style">
                @if (entry.Key == "GitHub")
                {
                    <svg class="provider-logo" viewBox="0 0 24 24" fill="currentColor" style="color: #000;" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.43 9.8 8.23 11.38.6.11.82-.26.82-.57v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.4-1.34-1.78-1.34-1.78-1.09-.74.08-.72.08-.72 1.21.08 1.84 1.25 1.84 1.25 1.07 1.83 2.81 1.3 3.49 1.05.11-.82.42-1.3.76-1.6-2.67-.3-5.48-1.34-5.48-5.94 0-1.31.46-2.38 1.25-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.02-.32 3.33 1.23a11.53 11.53 0 016 0c2.31-1.55 3.33-1.23 3.33-1.23.66 1.66.25 2.88.12 3.18.79.84 1.25 1.91 1.25 3.22 0 4.65-2.8 5.63-5.49 5.94.42.36.81 1.09.81 2.22v3.29c0 .31.22.68.82.57C20.57 21.8 24 17.31 24 12c0-6.63-5.37-12-12-12z"/>
                    </svg>
                }
                <span style="@(textColor != null ? $"color: {textColor};" : null)">@entry.DisplayName</span>
            </a>
        }

        @if (Model.Providers.Any(p => p.Key == "MagicCode"))
        {
            <div class="code">
                <p style="font-size: 1rem; color: #777;">have an authentication code?</p>
                <form action="/account/login" method="post">
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="provider" value="MagicCode" />
                    <label>
                        <input type="text" name="code" style="font-size: 1rem; padding: 10px; border: 1px solid #7cc; background-color: #fff" />
                    </label>
                    <button type="submit" class="code-button" style="background: #fff; cursor: pointer;">
                        <span class="code-text">SUBMIT</span>
                    </button>
                </form>
            </div>
        }

    </div>

</div>

</body>
</html>
