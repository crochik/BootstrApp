@model IDP.Models.ErrorViewModel
@{
    Layout = null;
    ViewData["Title"] = "Error";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>

    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
            background-color: #f7fafc;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .card {
            background-color: #fff;
            max-width: 512px;
            width: 100%;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            border-radius: 1rem;
            border-top: 8px solid #dc2626;
            transition: all 300ms ease;
            box-sizing: border-box;
        }
        .card:hover {
            box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.3);
            transform: translateY(-2px);
        }
        @@media (min-width: 640px) {
            .card {
                padding: 2.5rem;
            }
        }

        .header {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .icon {
            width: 4rem;
            height: 4rem;
            color: #dc2626;
            margin: 0 auto 1rem;
            display: block;
        }
        .title {
            font-size: 1.875rem;
            font-weight: 800;
            color: #111827;
            margin: 0 0 0.5rem 0;
        }
        .subtitle {
            font-size: 1.125rem;
            color: #6b7280;
            margin: 0;
        }

        .alert-box {
            background-color: #fef2f2;
            border-left: 4px solid #f87171;
            padding: 1rem;
            border-radius: 0.5rem;
            margin-bottom: 2rem;
        }
        .alert-content {
            display: flex;
            align-items: flex-start;
        }
        .alert-icon-container {
            flex-shrink: 0;
            color: #b91c1c;
            margin-right: 0.75rem;
        }
        .alert-icon {
            width: 1.25rem;
            height: 1.25rem;
        }
        .alert-body {
            margin-left: 0.75rem;
        }
        .alert-heading {
            font-size: 0.875rem;
            font-weight: 600;
            color: #991b1b;
            margin: 0;
        }
        .alert-text-container {
            margin-top: 0.25rem;
            font-size: 0.875rem;
            color: #b91c1c;
        }
        .alert-text-container p {
            margin: 0;
        }

        .actions {
            text-align: center;
        }
        .actions h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #1f2937;
            margin: 0 0 1rem 0;
        }
        .actions p {
            color: #4b5563;
            margin: 0 0 1.5rem 0;
        }

        .footer-id {
            font-size: 0.75rem;
            color: #9ca3af;
            margin-top: 2rem;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="card">

    <div class="header">
        <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h1 class="title">
            Access Denied
        </h1>
        <p class="subtitle">
            A critical error occurred during login.
        </p>
    </div>

    @if (Model?.Error != null)
    {
        <div class="alert-box">
            <div class="alert-content">
                <div class="alert-icon-container">
                    <svg class="alert-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="alert-body">
                    <p class="alert-heading">@Model.Error.Error</p>
                    @if (!string.IsNullOrWhiteSpace(Model.Error.ErrorDescription))
                    {
                        <div class="alert-text-container">
                            <p>@Model.Error.ErrorDescription</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert-box">
            <div class="alert-content">
                <div class="alert-icon-container">
                    <svg class="alert-icon" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="alert-body">
                    <div class="alert-text-container">
                        <p>An unexpected error occurred.</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="actions">
        <h2>
            Need Immediate Help?
        </h2>
        <p>
            Please contact your Account Administrator for system access review or to reset your credentials.
        </p>
    </div>

    @if (Model?.Error?.RequestId != null)
    {
        <div class="footer-id">
            Request Id: @Model.Error.RequestId
        </div>
    }
</div>

</body>
</html>
