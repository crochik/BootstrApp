<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Webhook.Zapier</RootNamespace>
    <AssemblyName>Webhook.Zapier</AssemblyName>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Webhook.Zapier.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Shared discovery/catalog, subscription bridge, API-key gate and durable
         delivery (via Webhook.Publisher). This project adds only the Zapier API. -->
    <ProjectReference Include="..\Webhook.Integrations.Core\Webhook.Integrations.Core.csproj" />
  </ItemGroup>

</Project>
